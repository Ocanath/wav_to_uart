{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug player",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/examples/dartt_wav_player",
            "args": ["${workspaceFolder}/scripts/RebelPathCello_processed.wav", "0", "72", "--baudrate", "921600"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "build"
        },
        {
            "name": "Debug Ceedling Test",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/test/out/${fileBasenameNoExtension}/${fileBasenameNoExtension}.out",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "ceedling build test"
        }
    ]
}
