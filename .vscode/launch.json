{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug wav_parser",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/wav_parser",
            "args": ["build/bin/IsAnyOneThere_processed.wav", "0", "71", "--baudrate", "921600"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "build"
        }
    ]
}
